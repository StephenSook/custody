# Custody environment template. Copy to .env and fill in. NEVER commit .env.
# All credential-free: AWS access is via Vercel OIDC federation to an IAM role.

# Aurora DSQL regional endpoints (provisioned via the Vercel AWS integration or the AWS console)
# Region A (primary): us-east-1
DSQL_ENDPOINT_EAST=your-east-cluster-id.dsql.us-east-1.on.aws
# Region B (peer): us-east-2
DSQL_ENDPOINT_WEST=your-west-cluster-id.dsql.us-east-2.on.aws
DSQL_DATABASE=postgres
DSQL_USER=admin

# AWS / OIDC. No stored secret keys. The runtime role is scoped to dsql:DbConnect on the cluster ARN.
AWS_REGION=us-east-1
AWS_ROLE_ARN=arn:aws:iam::000000000000:role/custody-vercel-oidc

# Injected automatically by the Vercel AWS DSQL integration (do not hand-set in production):
# PGHOST=
# PGUSER=
# PGDATABASE=
# PGPORT=5432

# Demo mode. The synthetic-data demo has no login, so set DEMO_MODE=true to allow the
# mutation actions to run with the synthetic demo actor. Leave unset/false in any real
# deployment: the actor stub then fails closed and mutations require real authentication.
DEMO_MODE=true

# Upstash rate limiting (mutation routes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Ably hot-standby realtime provider
ABLY_API_KEY=
