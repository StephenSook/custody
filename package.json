{
  "name": "custody",
  "version": "0.1.0",
  "private": true,
  "description": "Globally-consistent parental-consent and minor-spend-control ledger on Amazon Aurora DSQL.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:integration": "vitest run tests/integration",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed/index.ts"
  },
  "dependencies": {
    "@aws/aurora-dsql-node-postgres-connector": "0.1.9",
    "@sd-jwt/core": "0.19.0",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@vercel/functions": "3.7.2",
    "@vercel/oidc-aws-credentials-provider": "3.1.5",
    "geist": "1.7.2",
    "lucide-react": "1.21.0",
    "motion": "12.40.0",
    "next": "16.2.9",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.9",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
